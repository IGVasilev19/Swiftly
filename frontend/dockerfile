# Build stage
FROM node:20 AS build
WORKDIR /app

# Install pnpm manually
RUN corepack enable

# Copy lockfiles
COPY package.json pnpm-lock.yaml ./

# Force Windows GitLab runner to run this through CMD, not PowerShell
RUN ["cmd.exe", "/C", "pnpm install --frozen-lockfile --prefer-offline"]

# Copy source
COPY . .

RUN ["cmd.exe", "/C", "pnpm run build"]

# Runtime stage
FROM nginx:stable
WORKDIR /usr/share/nginx/html
COPY --from=build /app/dist .  # Vite output
EXPOSE 80
