# ---------- Build Stage ----------
FROM node:20 AS build
WORKDIR /app

# Copy package metadata first for caching
COPY package*.json ./

# Install dependencies using faster, reproducible method
# - npm ci: clean, deterministic, MUCH faster than npm install
# - --no-audit: skips slow audit
# - --omit=optional: ignores optional deps that slow Windows runners
# - --quiet: reduces log overhead in CI
RUN npm ci --no-audit --omit=optional --quiet

# Copy rest of the source
COPY . .

# Build the production bundle
RUN npm run build

# ---------- Serve Stage ----------
FROM nginx:stable

# Copy built frontend into Nginx static root
COPY --from=build /app/build /usr/share/nginx/html

EXPOSE 80
