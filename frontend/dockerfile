# ---------- Build Stage ----------
FROM node:20 AS build
WORKDIR /app

# Install pnpm globally (best practice for CI)
RUN npm install -g pnpm

# Copy only package manifests first for caching
COPY package.json pnpm-lock.yaml ./

# Install dependencies using pnpm (fast + cached)
RUN pnpm install --frozen-lockfile --prefer-offline

# Copy the rest of the source code
COPY . .

# Build your React app (or Vite/Next/etc.)
RUN pnpm build


# ---------- Runtime Stage ----------
FROM nginx:stable
WORKDIR /usr/share/nginx/html

# Copy built assets from build step
COPY --from=build /app/dist .   # or /app/build depending on your config

EXPOSE 80
